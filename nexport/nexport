#!/usr/bin/env bash

NEXPORT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
NEXPORT_INSTALL_PATH="/usr/local/bin/nexport"
NEXPORT_INSTALL_DIR="/usr/local/lib/nexport"

source "$NEXPORT_DIR/lib/colors.sh"
source "$NEXPORT_DIR/lib/ui.sh"
source "$NEXPORT_DIR/data/ports_db.sh"
source "$NEXPORT_DIR/data/ports_db_ext1.sh"
source "$NEXPORT_DIR/data/ports_db_ext2.sh"
source "$NEXPORT_DIR/data/ports_db_ext3.sh"
source "$NEXPORT_DIR/modules/lookup.sh"
source "$NEXPORT_DIR/modules/search.sh"
source "$NEXPORT_DIR/modules/category.sh"
source "$NEXPORT_DIR/modules/top_ports.sh"
source "$NEXPORT_DIR/modules/quiz.sh"
source "$NEXPORT_DIR/modules/nmap_scan.sh"
source "$NEXPORT_DIR/modules/summarizer.sh"
source "$NEXPORT_DIR/modules/export.sh"
source "$NEXPORT_DIR/modules/api_intel.sh"

_nexport_install() {
  if [[ $EUID -ne 0 ]]; then
    echo -e "\n  ${YELLOW}${WARN} Run with sudo to install system-wide:${RESET}"
    echo -e "  ${GREEN}sudo $0 --install${RESET}\n"
    return 1
  fi

  echo -e "\n  ${CYAN}Installing NEXPORT to system...${RESET}"

  if [[ -d "$NEXPORT_INSTALL_DIR" ]]; then
    rm -rf "$NEXPORT_INSTALL_DIR"
  fi

  mkdir -p "$NEXPORT_INSTALL_DIR"
  cp -r "$NEXPORT_DIR/lib" "$NEXPORT_INSTALL_DIR/"
  cp -r "$NEXPORT_DIR/data" "$NEXPORT_INSTALL_DIR/"
  cp -r "$NEXPORT_DIR/modules" "$NEXPORT_INSTALL_DIR/"

  cat > "$NEXPORT_INSTALL_PATH" << WRAPPER
#!/usr/bin/env bash
NEXPORT_DIR="$NEXPORT_INSTALL_DIR"
source "\$NEXPORT_DIR/lib/colors.sh"
source "\$NEXPORT_DIR/lib/ui.sh"
source "\$NEXPORT_DIR/data/ports_db.sh"
source "\$NEXPORT_DIR/data/ports_db_ext1.sh"
source "\$NEXPORT_DIR/data/ports_db_ext2.sh"
source "\$NEXPORT_DIR/data/ports_db_ext3.sh"
source "\$NEXPORT_DIR/modules/lookup.sh"
source "\$NEXPORT_DIR/modules/search.sh"
source "\$NEXPORT_DIR/modules/category.sh"
source "\$NEXPORT_DIR/modules/top_ports.sh"
source "\$NEXPORT_DIR/modules/quiz.sh"
source "\$NEXPORT_DIR/modules/nmap_scan.sh"
source "\$NEXPORT_DIR/modules/summarizer.sh"
source "\$NEXPORT_DIR/modules/export.sh"
source "\$NEXPORT_DIR/modules/api_intel.sh"
source "$NEXPORT_INSTALL_DIR/nexport_main.sh" "\$@"
WRAPPER

  cp "$NEXPORT_DIR/nexport" "$NEXPORT_INSTALL_DIR/nexport_main.sh"
  chmod +x "$NEXPORT_INSTALL_PATH"
  chmod -R 755 "$NEXPORT_INSTALL_DIR"

  echo -e "  ${GREEN}${OK} Installed: ${WHITE}${NEXPORT_INSTALL_PATH}${RESET}"
  echo -e "  ${GREEN}${OK} Library:   ${WHITE}${NEXPORT_INSTALL_DIR}${RESET}"
  echo -e "  ${CYAN}Run ${WHITE}nexport${CYAN} from anywhere.${RESET}\n"
}

_nexport_uninstall() {
  if [[ $EUID -ne 0 ]]; then
    echo -e "\n  ${YELLOW}Run with sudo to uninstall: ${GREEN}sudo nexport --uninstall${RESET}\n"
    return 1
  fi
  rm -f "$NEXPORT_INSTALL_PATH"
  rm -rf "$NEXPORT_INSTALL_DIR"
  echo -e "\n  ${GREEN}${OK} NexPort uninstalled.${RESET}\n"
}

