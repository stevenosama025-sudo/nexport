_dispatch() {
  local cmd="$1"
  local args="${2:-}"

  case "$cmd" in
    "-h"|"--info")
      [[ -z "$args" ]] && show_help || lookup_port "$args" ;;
    "--help")
      show_help ;;
    "--version")
      echo -e "\n  ${CYAN}NEXPORT — Intelligent Threat Analysis Suite${RESET}\n" ;;
    "--install")
      _nexport_install ;;
    "--uninstall")
      _nexport_uninstall ;;
    "-a"|"--all")
      show_all ;;
    "-t"|"--top")
      show_top_ports ;;
    "-s"|"--search")
      [[ -z "$args" ]] && echo -e "\n  ${RED}Usage: -s <keyword>${RESET}\n" || search_ports "$args" ;;
    "-c"|"--category")
      [[ -z "$args" ]] && list_categories || show_category "$args" ;;
    "-p"|"--protocol")
      [[ -z "$args" ]] && echo -e "\n  ${RED}Usage: -p <tcp|udp|both>${RESET}\n" || filter_by_protocol "$args" ;;
    "-e"|"--encryption")
      [[ -z "$args" ]] && echo -e "\n  ${RED}Usage: -e <yes|no|partial>${RESET}\n" || filter_by_encryption "$args" ;;
    "-r"|"--risk")
      [[ -z "$args" ]] && echo -e "\n  ${RED}Usage: -r <critical|high|medium|low>${RESET}\n" || filter_by_risk "$args" ;;
    "--cve")
      [[ -z "$args" ]] && echo -e "\n  ${RED}Usage: --cve <CVE-ID>${RESET}\n" || search_cves "$args" ;;
    "scan")
      [[ -z "$args" ]] && echo -e "\n  ${RED}Usage: scan <target>${RESET}\n" || run_nmap_scan "$args" ;;
    "paste"|"summarize")
      summarize_paste_mode ;;
    "export")
      [[ -z "$args" ]] && echo -e "\n  ${RED}Usage: export <json|csv|markdown|html>${RESET}\n" || export_db "$args" ;;
    "intel")
      intel_dispatch $args ;;
    "-q"|"--quiz")
      quiz_mode ;;
    "exit"|"quit"|"q")
      echo -e "\n  ${CYAN}NexPort signing off. Stay secure.${RESET}\n"
      exit 0 ;;
    "")
      : ;;
    *)
      lookup_port "$cmd" ;;
  esac
}

_handle_cli_args() {
  local cmd="$1"
  shift

  case "$cmd" in
    "-h"|"--info")       _dispatch "-h" "${1:-}" ;;
    "-s"|"--search")     _dispatch "-s" "${1:-}" ;;
    "-c"|"--category")   _dispatch "-c" "${1:-}" ;;
    "-p"|"--protocol")   _dispatch "-p" "${1:-}" ;;
    "-e"|"--encryption") _dispatch "-e" "${1:-}" ;;
    "-r"|"--risk")       _dispatch "-r" "${1:-}" ;;
    "--cve")             _dispatch "--cve" "${1:-}" ;;
    "scan")              _dispatch "scan" "${1:-}" ;;
    "export")            _dispatch "export" "${1:-}" ;;
    "-a"|"--all")        _dispatch "-a" ;;
    "-t"|"--top")        _dispatch "-t" ;;
    "-q"|"--quiz")       _dispatch "-q" ;;
    "--help")            show_help ;;
    "--version")         _dispatch "--version" ;;
    "--install")         _nexport_install ;;
    "--uninstall")       _nexport_uninstall ;;
    "paste"|"summarize") _dispatch "paste" ;;
    "intel")             intel_dispatch "${@}" ;;
    *)                   lookup_port "$cmd" ;;
  esac
}

_prompt_loop() {
  while true; do
    echo -ne "  ${GREEN}nexport${RESET}${GRAY}>${RESET} "
    read -r input
    [[ -z "$input" ]] && continue

    local cmd="${input%% *}"
    local args=""
    [[ "$input" == *" "* ]] && args="${input#* }"

    _dispatch "$cmd" "$args"
  done
}

_auto_install_check() {
  if [[ ! -f "$NEXPORT_INSTALL_PATH" && $EUID -eq 0 ]]; then
    echo -e "\n  ${YELLOW}[*]${RESET} First run detected. Installing NexPort system-wide..."
    _nexport_install
  fi
}

if [[ $# -gt 0 ]]; then
  source "$NEXPORT_DIR/lib/colors.sh" 2>/dev/null
  _handle_cli_args "$@"
else
  _auto_install_check
  show_banner
  _prompt_loop
fi
